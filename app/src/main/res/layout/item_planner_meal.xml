<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/light_green">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivPlanMealImg"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImageView"
            tools:src="@tools:sample/avatars"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvPlanMealName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            tools:text="Meal for the Plan"
            app:layout_constraintStart_toEndOf="@id/ivPlanMealImg"
            app:layout_constraintTop_toTopOf="@id/ivPlanMealImg"
            app:layout_constraintEnd_toStartOf="@id/btnRemovePlan"/>

        <TextView
            android:id="@+id/tvPlanMealArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="Category | Area"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:alpha="0.9"
            app:layout_constraintStart_toStartOf="@id/tvPlanMealName"
            app:layout_constraintTop_toBottomOf="@id/tvPlanMealName"
            app:layout_constraintEnd_toEndOf="@id/tvPlanMealName"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvPlanMealArea"
            app:layout_constraintStart_toStartOf="@id/tvPlanMealName"
            app:layout_constraintEnd_toStartOf="@id/btnRemovePlan"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPlanIng1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#496134"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvPlanIng1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Ing 1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/light_text"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardPlanIng2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#496134">

                <TextView
                    android:id="@+id/tvPlanIng2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Ing 2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/light_text"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <ImageView
            android:id="@+id/btnRemovePlan"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/primary"
            android:padding="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>