<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MealWise" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="android:statusBarColor">@color/transparent</item>

        <item name="android:windowLightStatusBar">false</item>
    </style>


    <style name="Theme.MealWise" parent="Base.Theme.MealWise" />

    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/background_dark</item>

        <item name="itemActiveIndicatorStyle">@style/MyCustomIndicator</item>
    </style>

    <style name="MyCustomIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/light_green</item>
    </style>
    <style name="CustomCalendarTheme" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="colorAccent">@color/light_green</item>
        <item name="android:textColorSecondary">@color/light_green</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
    <style name="CalenderDateText" parent="TextAppearance.AppCompat.Medium">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="RoundedImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item> </style>

    <style name="CalenderWeekDayText" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/more_light_green</item> <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CustomChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/bg_chip_state_list</item>
        <item name="android:textColor">@color/white</item>
        <item name="chipStrokeColor">@color/primary</item>
        <item name="chipStrokeWidth">1dp</item>

        <item name="android:checkable">true</item>
        <item name="checkedIconVisible">true</item>
        <item name="checkedIconTint">@color/white</item> </style>
</resources>